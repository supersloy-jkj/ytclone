# ── LOCAL DEVELOPMENT ──────────────────────────────────────────────────────────
# Copy this file to .env and fill in values.
# Never commit the real .env to git.

SECRET_KEY=django-insecure-replace-this-with-a-real-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1

# Leave blank locally → Django uses SQLite automatically
DATABASE_URL=

# Leave blank locally → uploads save to ./media on disk
# On Vercel this MUST be set (disk is ephemeral there)
# Format: cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_URL=

# ── VERCEL ENVIRONMENT VARIABLES (set in Project Settings) ─────────────────────
# SECRET_KEY=<generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())">
# DEBUG=False
# ALLOWED_HOSTS=.vercel.app
# CSRF_TRUSTED_ORIGINS=https://*.vercel.app
# DATABASE_URL=postgres://user:pass@host/db?sslmode=require
# CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
